# Telegram API Bilgileri (my.telegram.org'dan alın)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Oturum dosyası adı
SESSION_NAME=my_session

# Kanal ID'leri (negatif değerler, virgülle ayrılmış)
# Tek kanal: -1001234567890
# Çoklu kanal: -1001234567890,-1001234567891,-1001234567892
SOURCE_CHANNEL_ID=-1001234567890
TARGET_CHANNEL_ID=-1001234567891

# Mesaj filtreleme (opsiyonel)
# Boş bırakılırsa tüm mesajlar aktarılır
FILTER_KEYWORDS=